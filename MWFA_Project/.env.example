# ─────────────────────────────────────────────────────────────
# MWFA — Environment Variables Template
# انسخ هذا الملف إلى .env وعدّل القيم
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="file:/data/mwfa.db"

# ── Web App ───────────────────────────────────────────────────
PORT=3001

# ── MQTT Broker ───────────────────────────────────────────────
# إذا كنت تشغّل بدون Docker:
#   MQTT_HOST=YOUR_VPS_IP
# إذا كنت تشغّل داخل docker-compose:
#   MQTT_HOST=mosquitto
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Kali-MCP ──────────────────────────────────────────────────
# Kali-MCP (Railway Production)
# https://kali-mcp-server-production-8297.up.railway.app
MCP_URL=https://kali-mcp-server-production-8297.up.railway.app
MCP_TIMEOUT=60000

# ── MQTT Authentication (اختياري) ─────────────────────────────
# لتوليد ملف passwd:
#   docker exec -it mwfa-mosquitto mosquitto_passwd -c /mosquitto/config/passwd admin
# ثم عدّل mosquitto.conf لتفعيل المصادقة
